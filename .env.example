# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# OpenAI — required for CV parsing and scoring
OPENAI_API_KEY=sk-your-key-here

# Google Sheets — CRM database (MVP default)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_SHEET_NAME=Acreva_HireFlow_CRM

# Gmail SMTP — required for outreach emails only
EMAIL_SENDER=your.email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password

# Optional app metadata
APP_TITLE=Acreva HireFlow
APP_VERSION=1.0.0

# Client demo mode — when true, emails are preview-only (safe for live presentations)
DEMO_MODE=true
